# Core
MAX_STORIES_PER_DAY=5
TARGET_VIDEO_LENGTH=45

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AI-News-Agent/1.0 by YourUsername

# YouTube (optional)
# Put OAuth file at config/client_secrets.json

# TikTok auto upload (optional)
TIKTOK_AUTO_UPLOAD=0
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_BASE_URL=https://open.tiktokapis.com
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_DISABLE_COMMENT=0
TIKTOK_DISABLE_DUET=0
TIKTOK_DISABLE_STITCH=0
